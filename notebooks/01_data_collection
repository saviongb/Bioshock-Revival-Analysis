    "import requests   # call the API\n",
    "import json       # saves data to file\n",
    "import time       # pauses between requests"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "7a5a3f15-976c-4403-9acc-27acc4881fd8",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_reviews(appid):\n",
    "    reviews = []          # the pile we're collecting into\n",
    "    cursor = \"*\"          # Steam's bookmark\n",
    "\n",
    "    while True:\n",
    "        params = {\n",
    "            \"json\": 1,\n",
    "            \"filter\": \"recent\",\n",
    "            \"language\": \"english\",\n",
    "            \"num_per_page\": 100,\n",
    "            \"cursor\": cursor,\n",
    "        }\n",
    "        url = \"https://store.steampowered.com/appreviews/\" + str(appid)\n",
    "        response = requests.get(url, params=params)\n",
    "        data = response.json()\n",
    "\n",
    "        if data[\"reviews\"] == []:     # empty page means done\n",
    "            break\n",
    "\n",
    "        reviews = reviews + data[\"reviews\"]   # add this page to the pile\n",
    "        cursor = data[\"cursor\"]               # move the bookmark forward\n",
    "\n",
    "        print(len(reviews), \"reviews so far\")\n",
    "        time.sleep(0.5)\n",
    "\n",
    "    return reviews"
   ]
  },
